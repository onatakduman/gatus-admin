# Bcrypt hash of the admin password.
# Generate with: docker run --rm ghcr.io/onatakduman/gatus-admin:latest /hashpw mypassword
# Or locally: go run ./cmd/hashpw mypassword
# IMPORTANT: wrap the hash in single quotes so Docker Compose does not interpret the $ signs.
ADMIN_PASSWORD_HASH='$2a$12$CHANGE_ME_BCRYPT_HASH_HERE'

# Random string used to sign session cookies. Rotate to invalidate all sessions.
# Generate with: openssl rand -hex 32
SECRET_KEY=change_me_to_a_long_random_string

# Where the "View Status Page" link points. Should be the public URL of your Gatus.
STATUS_URL=https://status.example.com
